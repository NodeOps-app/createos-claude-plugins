#!/usr/bin/env bash
# cos — drive a CreateOS sandbox as remote compute for Claude / agents.
#
# Two patterns:
#   one-shot offload (safe default): stage a dir → run → pull artifacts → destroy
#   live session (opt-in):           a reusable named box + two-way Mutagen sync
#
# Subcommands:
#   cos offload [-s SHAPE] [-r ROOTFS] [-e EGRESS]... <local-dir> <cmd> [-o OUT]
#       tar <local-dir> into a fresh box at /work, run <cmd> there, optionally pull
#       /work/<OUT> back into <local-dir>, then ALWAYS destroy the box.
#   cos up   [-s SHAPE] [-r ROOTFS] [-n NAME]   create-or-reuse a project box; record it active
#   cos run  <cmd>                              exec <cmd> in the active project box (streamed)
#   cos sync <local-dir> [remote-dir]           start two-way sync into the active box (background)
#   cos down                                    stop sync + destroy active box + clear state
#   cos status                                  show active box + sync state
#
# Driver is the authed `createos` CLI. `createos sandbox create` renders a TTY
# spinner even under `-o json`, so every create tags a unique --name and resolves
# the id from `createos -o json sandbox ls`.
set -euo pipefail

CLI=${COS_CLI:-createos}
STATE_DIR=${COS_STATE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/createos-sandbox}
mkdir -p "$STATE_DIR"

# one active box per project root (git toplevel, else cwd)
proj_key(){ local root; root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); printf '%s' "$root" | shasum | cut -c1-12; }
STATE="$STATE_DIR/$(proj_key).json"

die(){ echo "cos: $*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }
have "$CLI" || die "createos CLI not found (set COS_CLI)"
have jq    || die "jq required"

# resolve a sandbox id by the unique name we created it with
resolve_id(){ "$CLI" -o json sandbox ls 2>/dev/null | jq -r --arg n "$1" '.[]|select(.name==$n).id' | head -1; }

create_box(){ # $1=name $2=shape $3=rootfs ; extra --egress in COS_EGRESS array
  local args=(sandbox create --name "$1" --shape "$2" --rootfs "$3" --auto-pause 30m)
  [ "${#COS_EGRESS[@]}" -gt 0 ] && args+=("${COS_EGRESS[@]}")   # only add egress when set (no stray empty arg)
  "$CLI" "${args[@]}" >"$STATE_DIR/last-create.log" 2>&1 || die "create failed for $1 — see $STATE_DIR/last-create.log"
  local id; id=$(resolve_id "$1"); [ -n "$id" ] && [ "$id" != null ] || die "could not resolve $1"
  printf '%s' "$id"
}

state_get(){ [ -f "$STATE" ] && jq -r --arg k "$1" '.[$k] // empty' "$STATE" 2>/dev/null || true; }
state_set(){ # k v ...
  local tmp; tmp=$(mktemp); [ -f "$STATE" ] || echo '{}' > "$STATE"
  local f="$STATE"; local jqargs=() prog='.'
  while [ $# -ge 2 ]; do jqargs+=(--arg "k$#" "$1" --arg "v$#" "$2"); prog="$prog | .[\$k$#]=\$v$#"; shift 2; done
  jq "${jqargs[@]}" "$prog" "$f" > "$tmp" && mv "$tmp" "$f"
}

# ─────────────────────────────────────────────────────────────── one-shot offload
cmd_offload(){
  local shape=s-1vcpu-1gb rootfs=devbox:1 out="" ; COS_EGRESS=()
  while getopts "s:r:e:o:" o; do case $o in
    s) shape=$OPTARG;; r) rootfs=$OPTARG;; e) COS_EGRESS+=(--egress "$OPTARG");; o) out=$OPTARG;;
    *) die "usage: cos offload [-s shape] [-r rootfs] [-e egress]... <local-dir> <cmd> [-o out]";; esac; done
  shift $((OPTIND-1))
  local dir=${1:?local-dir required}; local cmd=${2:?cmd required}
  [ -d "$dir" ] || die "no such dir: $dir"
  local name="cos-o-$$-${RANDOM}" id; id=$(create_box "$name" "$shape" "$rootfs")  # ≤22 chars (CreateOS name cap)
  echo "cos: $id ($name, $shape/$rootfs)" >&2
  # shellcheck disable=SC2064
  trap "$CLI sandbox rm -y $id >/dev/null 2>&1 && echo 'cos: destroyed $id' >&2" EXIT

  tar -c -C "$dir" . | "$CLI" sandbox push "$id" - /work.tar >/dev/null 2>&1
  "$CLI" sandbox exec --stream "$id" -- bash -lc \
    "mkdir -p /work && tar -C /work -xf /work.tar && rm -f /work.tar && cd /work && { $cmd; }"
  local rc=$?
  if [ -n "$out" ]; then
    echo "cos: pulling /work/$out → $dir/" >&2
    "$CLI" sandbox exec "$id" -- bash -lc "cd /work && tar -c $out" \
      | tar -x -C "$dir" 2>/dev/null || echo "cos: pull of '$out' failed (continuing)" >&2
  fi
  return $rc
}

# ───────────────────────────────────────────────────────────── reusable project box
cmd_up(){
  local shape=s-2vcpu-2gb rootfs=devbox:1 name="" ; COS_EGRESS=()
  while getopts "s:r:n:e:" o; do case $o in
    s) shape=$OPTARG;; r) rootfs=$OPTARG;; n) name=$OPTARG;; e) COS_EGRESS+=(--egress "$OPTARG");;
    *) die "usage: cos up [-s shape] [-r rootfs] [-n name]";; esac; done
  local cur; cur=$(state_get id)
  if [ -n "$cur" ] && [ "$("$CLI" -o json sandbox ls 2>/dev/null | jq -r --arg i "$cur" '.[]|select(.id==$i)|.status')" = running ]; then
    echo "cos: reusing $cur ($(state_get name))" >&2; return 0
  fi
  [ -n "$name" ] || name="cos-proj-$(proj_key)"
  local id; id=$(create_box "$name" "$shape" "$rootfs")
  state_set id "$id" name "$name" shape "$shape"
  echo "cos: project box up: $id ($name, $shape)" >&2
}

cmd_run(){
  local id; id=$(state_get id); [ -n "$id" ] || die "no active box — run 'cos up' first"
  "$CLI" sandbox exec --stream "$id" -- bash -lc "$*"
}

cmd_sync(){
  local id; id=$(state_get id); [ -n "$id" ] || die "no active box — run 'cos up' first"
  local mode=one-way; local -a excl=()       # default ONE-WAY: laptop→box, no bleed-back
  while getopts "2Mx:" o; do case $o in
    2) mode=two-way;; M) mode=mirror;; x) excl+=(--exclude "$OPTARG");;
    *) die "usage: cos sync [-2|-M] [-x glob]... <local-dir> [remote-dir]";; esac; done
  shift $((OPTIND-1))
  local dir=${1:?local-dir required}; local remote=${2:-/work}
  [ -d "$dir" ] || die "no such dir: $dir"
  # createos CLI requires the local path under $HOME or literal /tmp (it does NOT
  # canonicalize, so /private/tmp/* is rejected — pass the path as given).
  case "$dir" in "$HOME"/*|/tmp/*) :;; *) die "sync local dir must be under \$HOME or /tmp: $dir";; esac
  case "$remote" in /etc*|/usr*|/bin*|/sbin*|/lib*) die "refusing sync to system dir $remote";; esac

  # flags must precede the positional <sandbox> (urfave stops flag parsing after it)
  local -a args=(sandbox sync --local "$dir" --remote "$remote" -y)
  if "$CLI" sandbox sync --help 2>/dev/null | grep -q -- '--mode'; then
    args+=(--mode "$mode"); [ "${#excl[@]}" -gt 0 ] && args+=("${excl[@]}")
  else   # old CLI: only two-way exists, no excludes
    [ "$mode" != two-way ] && echo "cos: ⚠ installed createos CLI lacks --mode; falling back to TWO-WAY (box writes bleed back). Upgrade the CLI for one-way/mirror." >&2
    [ "${#excl[@]}" -gt 0 ] && echo "cos: ⚠ installed CLI lacks --exclude; ignoring -x globs." >&2
    mode=two-way
  fi

  case "$mode" in
    one-way) echo "cos: one-way sync $dir → $id:$remote (laptop wins; box changes NOT pulled back)" >&2;;
    two-way) echo "cos: ⚠ two-way sync — sandbox-side writes (build output, deps) flow BACK to $dir" >&2;;
    mirror)  echo "cos: ⚠ mirror — files on the box not present in $dir will be DELETED" >&2;;
  esac
  echo "cos: first run downloads Mutagen (~60-90s before edits propagate); .git skipped by default" >&2
  nohup "$CLI" "${args[@]}" >"$STATE_DIR/sync-$id.log" 2>&1 &
  state_set sync_pid "$!" sync_dir "$dir" sync_remote "$remote" sync_mode "$mode"
  echo "cos: sync pid $! ($mode, log: $STATE_DIR/sync-$id.log)" >&2
}

cmd_down(){
  local id pid; id=$(state_get id); pid=$(state_get sync_pid)
  [ -n "$pid" ] && kill "$pid" 2>/dev/null && echo "cos: stopped sync $pid" >&2 || true
  if [ -n "$id" ]; then "$CLI" sandbox rm -y "$id" >/dev/null 2>&1 && echo "cos: destroyed $id" >&2 || true; fi
  rm -f "$STATE"; echo "cos: state cleared" >&2
}

cmd_status(){
  [ -f "$STATE" ] || { echo "cos: no active box for this project"; return 0; }
  local id; id=$(state_get id)
  echo "active: $id ($(state_get name))  shape=$(state_get shape)"
  local pid; pid=$(state_get sync_pid)
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && echo "sync:   pid $pid  [$(state_get sync_mode)] $(state_get sync_dir) → $(state_get sync_remote)" || echo "sync:   none"
  "$CLI" -o json sandbox ls 2>/dev/null | jq -r --arg i "$id" '.[]|select(.id==$i)|"status: \(.status)  ip=\(.ip)"' || true
}

sub=${1:-}; shift || true
case "$sub" in
  offload) cmd_offload "$@";;
  up)      cmd_up "$@";;
  run)     cmd_run "$@";;
  sync)    cmd_sync "$@";;
  down)    cmd_down "$@";;
  status)  cmd_status "$@";;
  *) cat >&2 <<EOF
cos — CreateOS sandbox as remote compute.
  cos offload [-s shape] [-r rootfs] [-e egress]... <dir> <cmd> [-o out]   one-shot: stage→run→pull→destroy
  cos up   [-s shape] [-r rootfs] [-n name]                                create/reuse project box
  cos run  <cmd>                                                           exec in project box (streamed)
  cos sync [-2|-M] [-x glob]... <dir> [remote]                             sync into project box (bg); default one-way (laptop→box), -2 two-way, -M mirror
  cos down                                                                 stop sync + destroy box
  cos status                                                               show active box + sync
EOF
     exit 2;;
esac
